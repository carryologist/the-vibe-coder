# Required — Admin authentication
ADMIN_PASSWORD=
SESSION_SECRET=          # Random string for JWT signing (e.g., openssl rand -hex 32)

# Required — Content storage (GitHub)
GITHUB_TOKEN=            # Personal access token with repo contents write access
GITHUB_REPO=             # Format: owner/repo (e.g., carryologist/the-vibe-coder)

# Required — AI blog generation (Anthropic)
ANTHROPIC_API_KEY=       # Claude API key from console.anthropic.com

# Required — Analytics (Upstash Redis)
KV_REST_API_URL=         # Upstash Redis REST URL
KV_REST_API_TOKEN=       # Upstash Redis REST token

# Optional — Syndication
DEVTO_API_KEY=           # Dev.to API key for cross-posting
